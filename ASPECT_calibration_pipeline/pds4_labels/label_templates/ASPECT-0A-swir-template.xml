<?xml version="1.0" encoding="UTF-8"?>
<?xml-model href="https://pds.nasa.gov/pds4/pds/v1/PDS4_PDS_1M00.sch" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<?xml-model href="https://pds.nasa.gov/pds4/disp/v1/PDS4_DISP_1M00_1510.sch" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<?xml-model href="https://pds.nasa.gov/pds4/sp/v1/PDS4_SP_1M00_1320.sch" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<?xml-model href="https://pds.nasa.gov/pds4/img/v1/PDS4_IMG_1N00_1920.sch" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<?xml-model href="https://pds.nasa.gov/pds4/geom/v1/PDS4_GEOM_1N00_1980.sch" schematypens="http://purl.oclc.org/dsdl/schematron"?>
<?xml-model href="https://psa.esa.int/psa/v1/PDS4_PSA_1F00_1300.sch" schematypens="http://purl.oclc.org/dsdl/schematron"?>

<Product_Observational xmlns="http://pds.nasa.gov/pds4/pds/v1"
                        xmlns:disp="http://pds.nasa.gov/pds4/disp/v1"
                        xmlns:sp="http://pds.nasa.gov/pds4/sp/v1"
                        xmlns:img="http://pds.nasa.gov/pds4/img/v1"
                        xmlns:geom="http://pds.nasa.gov/pds4/geom/v1"
                        xmlns:psa="http://psa.esa.int/psa/v1"
                        xmlns:hera="http://psa.esa.int/psa/hera/v1"
                        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                        xmlns:pds="http://pds.nasa.gov/pds4/pds/v1"
                        xsi:schemaLocation="
                           http://pds.nasa.gov/pds4/pds/v1 https://pds.nasa.gov/pds4/pds/v1/PDS4_PDS_1M00.xsd
                           http://pds.nasa.gov/pds4/disp/v1 https://pds.nasa.gov/pds4/disp/v1/PDS4_DISP_1M00_1510.xsd
                           http://pds.nasa.gov/pds4/sp/v1 https://pds.nasa.gov/pds4/sp/v1/PDS4_SP_1M00_1320.xsd
                           http://pds.nasa.gov/pds4/img/v1 https://pds.nasa.gov/pds4/img/v1/PDS4_IMG_1N00_1920.xsd
                           http://pds.nasa.gov/pds4/geom/v1 https://pds.nasa.gov/pds4/geom/v1/PDS4_GEOM_1N00_1980.xsd
                           http://psa.esa.int/psa/v1 https://psa.esa.int/psa/v1/PDS4_PSA_1F00_1300.xsd">
                           <!-- http://psa.esa.int/psa/hera/v1 https://pds.esa.int/psa/hera/v1/PDS4_HERA_1E00_1000.xsd -->
   
   <!-- 
   This file is a template for .fits labels.

   Some general help:
   https://pds.nasa.gov/datastandards/documents/
   https://pds.nasa.gov/datastandards/dictionaries/index-1.22.0.0.shtml
   https://sbnwiki.asteroiddata.org/Notes_for_Labelling_FITS_files.html#Discipline_Dictionaries
   -->

   <!--
   Instructions for filling the missing fields can be found in:
   Common (pds): https://pds.nasa.gov/datastandards/documents/dd/v1/PDS4_PDS_DD_1M00.html
   Display dictionary (disp): https://sbnwiki.asteroiddata.org/Filling_Out_the_Display_Dictionary_Classes.html
   Spectral dictionary (sp): https://sbnwiki.asteroiddata.org/Filling_Out_the_Spectral_Dictionary_Classes.html
   Geometry dictionary (geom): https://sbnwiki.asteroiddata.org/Filling_Out_the_Geometry_Dictionary_Classes.html
   -->

   <Identification_Area>
      <logical_identifier>{{ lid }}</logical_identifier>
      <version_id>1.0</version_id>
      <title>{{ title }}</title>
      <information_model_version>1.22.0.0</information_model_version>
      <product_class>Product_Observational</product_class>
      
      <Modification_History>
         <Modification_Detail>
            <modification_date>{{ modification_date }}</modification_date>
            <version_id>1.0</version_id>
            <description>This PDS4 label was generated based on fits metadata.</description>
         </Modification_Detail>
      </Modification_History>
   </Identification_Area>

   <Observation_Area>
      <Time_Coordinates>
         <start_date_time>{{ start_time }}</start_date_time><!-- Example: 2024-08-20T21:58:35.202Z -->
         <stop_date_time>{{ stop_time }}</stop_date_time>
      </Time_Coordinates>

      <Primary_Result_Summary>
         <purpose>Science</purpose>
         <processing_level>{{ processing_level }}</processing_level>
         <Science_Facets>
            <wavelength_range>{{ wavelength_range }}</wavelength_range>
            <discipline_name>Spectroscopy</discipline_name>
         </Science_Facets>
      </Primary_Result_Summary>

      <Investigation_Area>
         <name>Hera</name>
         <type>Mission</type>
         <Internal_Reference>
            <lid_reference>urn:esa:psa:context:investigation:mission.hera</lid_reference>
            <reference_type>data_to_investigation</reference_type>
         </Internal_Reference>
      </Investigation_Area>

      <Observing_System>
         <Observing_System_Component>
            <name>Milani</name>
            <type>Host</type>
            <Internal_Reference>
               <lid_reference>urn:esa:psa:context:instrument_host:spacecraft.milani</lid_reference>
               <reference_type>is_instrument_host</reference_type>
            </Internal_Reference>
         </Observing_System_Component>
         <Observing_System_Component>
            <name>ASPECT</name>
            <type>Instrument</type>
            <description>Hyperspectral Imager</description>
            <Internal_Reference>
               <lid_reference>urn:esa:psa:context:instrument:milani.aspect</lid_reference>
               <reference_type>is_instrument</reference_type>
            </Internal_Reference>
         </Observing_System_Component>
      </Observing_System>

      <Target_Identification>
         <name>{{ target_name }}</name>
         <type>{{ target_type }}</type>
         <Internal_Reference>
            <lid_reference>{{ target_lid_reference }}</lid_reference>
            <reference_type>data_to_target</reference_type>
         </Internal_Reference>
      </Target_Identification>

      <Mission_Area>
         <psa:Mission_Information>
            <psa:spacecraft_clock_start_count>{{ spacecraft_clock_start_count }}</psa:spacecraft_clock_start_count>
            <psa:spacecraft_clock_stop_count>{{ spacecraft_clock_end_count }}</psa:spacecraft_clock_stop_count>
            <psa:mission_phase_name>{{ mission_phase }}</psa:mission_phase_name>
            <psa:mission_phase_identifier>urn:esa:psa:context:...</psa:mission_phase_identifier>
         </psa:Mission_Information>
         <!-- <hera:Hera_Parameters>To be defined later...
            <hera:Aspect_Parameters>
               <hera:detector_temp unit="degC">0</hera:detector_temp>Example
            </hera:Aspect_Parameters>
         </hera:Hera_Parameters> -->
      </Mission_Area>
      
      <Discipline_Area>
         <img:Imaging>
            <Local_Internal_Reference>
               <local_identifier_reference>{{ local_id }}</local_identifier_reference>
               <local_reference_type>imaging_parameters_to_image_object</local_reference_type>
            </Local_Internal_Reference>
            <img:Detector> <!-- To be defined later in collaboration with ESA -->
               <img:gain_number>0</img:gain_number> <!-- Example -->
            </img:Detector>
            <img:Exposure>
               <img:exposure_count>{{ naxis3 }}</img:exposure_count>
               <img:exposure_duration unit="s">{{ all_exposure_times }}</img:exposure_duration>
               <img:exposure_type>Manual</img:exposure_type><!-- Manual, Auto, or Test -->
            </img:Exposure>
         </img:Imaging>

         <!--
         Display dictionary section.
         Instructions can be found at https://sbnwiki.asteroiddata.org/Filling_Out_the_Display_Dictionary_Classes.html
         -->
         <disp:Display_Settings>
            <pds:Local_Internal_Reference>
               <pds:local_identifier_reference>{{ local_id }}</pds:local_identifier_reference>
               <pds:local_reference_type>display_settings_to_array</pds:local_reference_type>
            </pds:Local_Internal_Reference>
            <disp:Display_Direction>
               <disp:horizontal_display_axis>Sample</disp:horizontal_display_axis>
               <disp:horizontal_display_direction>Left to Right</disp:horizontal_display_direction>
               <disp:vertical_display_axis>Line</disp:vertical_display_axis>
               <disp:vertical_display_direction>Top to Bottom</disp:vertical_display_direction>
            </disp:Display_Direction>
         </disp:Display_Settings>

         <!--
         Geometry dictionary section.
         Instructions can be found at https://sbnwiki.asteroiddata.org/Filling_Out_the_Geometry_Dictionary_Classes.html
         -->
         <geom:Geometry>
				<geom:SPICE_Kernel_Files>
					<geom:SPICE_Kernel_Identification>
						<geom:kernel_type>MK</geom:kernel_type>
						<geom:spice_kernel_file_name>{{ spice_mk }}</geom:spice_kernel_file_name>
					</geom:SPICE_Kernel_Identification>
				</geom:SPICE_Kernel_Files>
         </geom:Geometry>

      </Discipline_Area>
   </Observation_Area>

   <File_Area_Observational>
      <File>
         <file_name>{{ filename }}</file_name>
         <creation_date_time>{{ creation_time }}</creation_date_time>
      </File>
      <Header>
         <name>PrimaryHDU</name>
         <offset unit="byte">{{ PrimaryHDU_offset }}</offset>
         <object_length unit="byte">{{ PrimaryHDU_size }}</object_length>
         <parsing_standard_id>FITS 3.0</parsing_standard_id>
         <description>{{ fits_header }}</description>
      </Header>
      <Array_3D_Spectrum>
         <pds:local_identifier>{{ local_id }}</pds:local_identifier>
         <offset unit="byte">{{ PrimaryHDU_size }}</offset><!-- Always a multiple of 2880 -->
         <axes>3</axes>
         <axis_index_order>Last Index Fastest</axis_index_order>
         <Element_Array>
            <data_type>{{ data_type }}</data_type>
            <unit>{{ unit }}</unit>
         </Element_Array>
         <Axis_Array>
            <axis_name>Wavelength</axis_name>
            <elements>{{ naxis3 }}</elements>
            <sequence_number>1</sequence_number>
         </Axis_Array>
         <Axis_Array>
            <axis_name>Line</axis_name>
            <elements>{{ naxis2 }}</elements>
            <sequence_number>2</sequence_number>
         </Axis_Array>
         <Axis_Array>
            <axis_name>Sample</axis_name>
            <elements>{{ naxis1 }}</elements>
            <sequence_number>3</sequence_number>
         </Axis_Array>
      </Array_3D_Spectrum>
   </File_Area_Observational>

</Product_Observational>
